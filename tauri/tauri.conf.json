{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "wie",
  "version": "0.1.0",
  "identifier": "net.dlunch.wie",
  "build": {
    "frontendDist": "../wie_web/dist",
    "devUrl": "http://localhost:8080",
    "beforeDevCommand": "npm start",
    "beforeBuildCommand": "npm run build:prod"
  },
  "app": {
    "windows": [
      {
        "title": "wie",
        "width": 800,
        "height": 600,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "capabilities": [
        {
          "identifier": "default",
          "description": "enables the default permissions",
          "windows": ["main"],
          "permissions": ["core:default"]
        }
      ],
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": ["icons/icon.png", "icons/Square310x310Logo.png"]
  }
}
